[
  { "id": "greet-01", "category": "greetings", "hanzi": "你好", "pinyin": "nǐ hǎo", "english": "hi / hello", "note": "Universal greeting. In casual texts and among friends, 嗨 or just 诶 is more common." },
  { "id": "greet-02", "category": "greetings", "hanzi": "您好", "pinyin": "nín hǎo", "english": "hello (polite)", "note": "Use for elders, strangers, customers, or in formal settings. Using 你好 to an elder can feel curt." },
  { "id": "greet-03", "category": "greetings", "hanzi": "嗨", "pinyin": "hāi", "english": "hi", "note": "Borrowed from English. Very casual — friends, chat apps." },
  { "id": "greet-04", "category": "greetings", "hanzi": "早", "pinyin": "zǎo", "english": "morning", "note": "Native speakers usually just say 早, not the textbook 早上好." },
  { "id": "greet-05", "category": "greetings", "hanzi": "晚安", "pinyin": "wǎn'ān", "english": "good night", "note": "Said at bedtime, not on arrival in the evening." },
  { "id": "greet-06", "category": "greetings", "hanzi": "再见", "pinyin": "zàijiàn", "english": "goodbye", "note": "A touch formal in speech; 拜拜 is far more common day-to-day." },
  { "id": "greet-07", "category": "greetings", "hanzi": "拜拜", "pinyin": "bài bài", "english": "bye", "note": "The casual goodbye everyone actually says." },
  { "id": "greet-08", "category": "greetings", "hanzi": "回头见", "pinyin": "huítóu jiàn", "english": "see you later" },
  { "id": "greet-09", "category": "greetings", "hanzi": "谢谢", "pinyin": "xièxie", "english": "thanks" },
  { "id": "greet-10", "category": "greetings", "hanzi": "多谢", "pinyin": "duōxiè", "english": "many thanks", "note": "Slightly warmer / more emphatic than 谢谢." },
  { "id": "greet-11", "category": "greetings", "hanzi": "不客气", "pinyin": "bú kèqi", "english": "you're welcome", "note": "Friends often just say 不用谢 or wave it off with 没事." },
  { "id": "greet-12", "category": "greetings", "hanzi": "没事", "pinyin": "méi shì", "english": "no worries / it's fine", "note": "The natural reply when a stranger apologises to you." },
  { "id": "greet-13", "category": "greetings", "hanzi": "对不起", "pinyin": "duìbuqǐ", "english": "sorry (serious)", "note": "Sincere apology. For small bumps use 不好意思 instead." },
  { "id": "greet-14", "category": "greetings", "hanzi": "不好意思", "pinyin": "bù hǎoyìsi", "english": "sorry / excuse me", "note": "The everyday 'sorry' — bumping someone, getting attention, mild apology." },
  { "id": "greet-15", "category": "greetings", "hanzi": "没关系", "pinyin": "méi guānxi", "english": "it doesn't matter" },
  { "id": "greet-16", "category": "greetings", "hanzi": "请问", "pinyin": "qǐng wèn", "english": "excuse me (may I ask)", "note": "How you start a question to a stranger — shopkeeper, passerby, etc." },
  { "id": "greet-17", "category": "greetings", "hanzi": "欢迎", "pinyin": "huānyíng", "english": "welcome" },
  { "id": "greet-18", "category": "greetings", "hanzi": "好久不见", "pinyin": "hǎojiǔ bú jiàn", "english": "long time no see" },
  { "id": "greet-19", "category": "greetings", "hanzi": "最近怎么样", "pinyin": "zuìjìn zěnmeyàng", "english": "how have you been?", "note": "More natural than the textbook 你好吗? — which people almost never actually say." },
  { "id": "greet-20", "category": "greetings", "hanzi": "挺好的", "pinyin": "tǐng hǎo de", "english": "pretty good", "note": "Casual, positive reply. Beats the stiff 我很好." },

  { "id": "pv-01", "category": "pronouns-verbs", "hanzi": "我", "pinyin": "wǒ", "english": "I / me" },
  { "id": "pv-02", "category": "pronouns-verbs", "hanzi": "你", "pinyin": "nǐ", "english": "you" },
  { "id": "pv-03", "category": "pronouns-verbs", "hanzi": "他", "pinyin": "tā", "english": "he / him" },
  { "id": "pv-04", "category": "pronouns-verbs", "hanzi": "她", "pinyin": "tā", "english": "she / her", "note": "Identical pronunciation to 他 — only written form differs." },
  { "id": "pv-05", "category": "pronouns-verbs", "hanzi": "我们", "pinyin": "wǒmen", "english": "we / us" },
  { "id": "pv-06", "category": "pronouns-verbs", "hanzi": "你们", "pinyin": "nǐmen", "english": "you (plural)" },
  { "id": "pv-07", "category": "pronouns-verbs", "hanzi": "他们", "pinyin": "tāmen", "english": "they / them" },
  { "id": "pv-08", "category": "pronouns-verbs", "hanzi": "这", "pinyin": "zhè", "english": "this", "note": "Often pronounced 'zhèi' in casual speech." },
  { "id": "pv-09", "category": "pronouns-verbs", "hanzi": "那", "pinyin": "nà", "english": "that", "note": "Often 'nèi' in speech, and also means 'then / in that case'." },
  { "id": "pv-10", "category": "pronouns-verbs", "hanzi": "是", "pinyin": "shì", "english": "to be (is / am / are)", "note": "Only links nouns, not adjectives — don't say 我是高." },
  { "id": "pv-11", "category": "pronouns-verbs", "hanzi": "有", "pinyin": "yǒu", "english": "to have / there is" },
  { "id": "pv-12", "category": "pronouns-verbs", "hanzi": "去", "pinyin": "qù", "english": "to go" },
  { "id": "pv-13", "category": "pronouns-verbs", "hanzi": "来", "pinyin": "lái", "english": "to come" },
  { "id": "pv-14", "category": "pronouns-verbs", "hanzi": "要", "pinyin": "yào", "english": "to want / will", "note": "Doubles as future marker: 我要去 = I'm going to go." },
  { "id": "pv-15", "category": "pronouns-verbs", "hanzi": "吃", "pinyin": "chī", "english": "to eat" },
  { "id": "pv-16", "category": "pronouns-verbs", "hanzi": "喝", "pinyin": "hē", "english": "to drink" },
  { "id": "pv-17", "category": "pronouns-verbs", "hanzi": "看", "pinyin": "kàn", "english": "to look / watch / read" },
  { "id": "pv-18", "category": "pronouns-verbs", "hanzi": "说", "pinyin": "shuō", "english": "to speak / say" },
  { "id": "pv-19", "category": "pronouns-verbs", "hanzi": "想", "pinyin": "xiǎng", "english": "to want to / miss / think" },
  { "id": "pv-20", "category": "pronouns-verbs", "hanzi": "做", "pinyin": "zuò", "english": "to do / make" },

  { "id": "num-01", "category": "numbers", "hanzi": "零", "pinyin": "líng", "english": "zero" },
  { "id": "num-02", "category": "numbers", "hanzi": "一", "pinyin": "yī", "english": "one", "note": "Tone shifts: yì before 4th tone (一起 yìqǐ), yí before non-4th (一个 yí gè)." },
  { "id": "num-03", "category": "numbers", "hanzi": "二", "pinyin": "èr", "english": "two", "note": "For counting only. To say 'two of something', use 两." },
  { "id": "num-04", "category": "numbers", "hanzi": "两", "pinyin": "liǎng", "english": "two (of something)", "note": "两个人 two people, 两块钱 two yuan." },
  { "id": "num-05", "category": "numbers", "hanzi": "三", "pinyin": "sān", "english": "three" },
  { "id": "num-06", "category": "numbers", "hanzi": "四", "pinyin": "sì", "english": "four" },
  { "id": "num-07", "category": "numbers", "hanzi": "五", "pinyin": "wǔ", "english": "five" },
  { "id": "num-08", "category": "numbers", "hanzi": "六", "pinyin": "liù", "english": "six" },
  { "id": "num-09", "category": "numbers", "hanzi": "七", "pinyin": "qī", "english": "seven" },
  { "id": "num-10", "category": "numbers", "hanzi": "八", "pinyin": "bā", "english": "eight" },
  { "id": "num-11", "category": "numbers", "hanzi": "九", "pinyin": "jiǔ", "english": "nine" },
  { "id": "num-12", "category": "numbers", "hanzi": "十", "pinyin": "shí", "english": "ten" },
  { "id": "num-13", "category": "numbers", "hanzi": "十一", "pinyin": "shí yī", "english": "eleven" },
  { "id": "num-14", "category": "numbers", "hanzi": "二十", "pinyin": "èrshí", "english": "twenty" },
  { "id": "num-15", "category": "numbers", "hanzi": "一百", "pinyin": "yìbǎi", "english": "one hundred" },
  { "id": "num-16", "category": "numbers", "hanzi": "一千", "pinyin": "yìqiān", "english": "one thousand" },
  { "id": "num-17", "category": "numbers", "hanzi": "一万", "pinyin": "yíwàn", "english": "ten thousand", "note": "Chinese groups by 10k, not 1k — so 'one million' is 一百万." },
  { "id": "num-18", "category": "numbers", "hanzi": "几", "pinyin": "jǐ", "english": "how many (small)", "note": "For expected answers under ~10. Use 多少 for larger or unknown quantities." },
  { "id": "num-19", "category": "numbers", "hanzi": "多少", "pinyin": "duōshao", "english": "how many / how much" },
  { "id": "num-20", "category": "numbers", "hanzi": "第一", "pinyin": "dì-yī", "english": "first" },

  { "id": "fam-01", "category": "family", "hanzi": "家", "pinyin": "jiā", "english": "home / family" },
  { "id": "fam-02", "category": "family", "hanzi": "爸爸", "pinyin": "bàba", "english": "dad", "note": "Casual. More formal: 父亲 fùqīn." },
  { "id": "fam-03", "category": "family", "hanzi": "妈妈", "pinyin": "māma", "english": "mom", "note": "Casual. More formal: 母亲 mǔqīn." },
  { "id": "fam-04", "category": "family", "hanzi": "爷爷", "pinyin": "yéye", "english": "grandpa (paternal)" },
  { "id": "fam-05", "category": "family", "hanzi": "奶奶", "pinyin": "nǎinai", "english": "grandma (paternal)" },
  { "id": "fam-06", "category": "family", "hanzi": "外公", "pinyin": "wàigōng", "english": "grandpa (maternal)" },
  { "id": "fam-07", "category": "family", "hanzi": "外婆", "pinyin": "wàipó", "english": "grandma (maternal)" },
  { "id": "fam-08", "category": "family", "hanzi": "哥哥", "pinyin": "gēge", "english": "older brother" },
  { "id": "fam-09", "category": "family", "hanzi": "姐姐", "pinyin": "jiějie", "english": "older sister" },
  { "id": "fam-10", "category": "family", "hanzi": "弟弟", "pinyin": "dìdi", "english": "younger brother" },
  { "id": "fam-11", "category": "family", "hanzi": "妹妹", "pinyin": "mèimei", "english": "younger sister" },
  { "id": "fam-12", "category": "family", "hanzi": "儿子", "pinyin": "érzi", "english": "son" },
  { "id": "fam-13", "category": "family", "hanzi": "女儿", "pinyin": "nǚ'ér", "english": "daughter" },
  { "id": "fam-14", "category": "family", "hanzi": "孩子", "pinyin": "háizi", "english": "child / kid" },
  { "id": "fam-15", "category": "family", "hanzi": "老公", "pinyin": "lǎogōng", "english": "husband", "note": "Casual, what people actually call their husband. 丈夫 is formal." },
  { "id": "fam-16", "category": "family", "hanzi": "老婆", "pinyin": "lǎopó", "english": "wife", "note": "Casual, everyday. 妻子 is formal." },
  { "id": "fam-17", "category": "family", "hanzi": "朋友", "pinyin": "péngyou", "english": "friend" },
  { "id": "fam-18", "category": "family", "hanzi": "男朋友", "pinyin": "nán péngyou", "english": "boyfriend" },
  { "id": "fam-19", "category": "family", "hanzi": "女朋友", "pinyin": "nǚ péngyou", "english": "girlfriend" },
  { "id": "fam-20", "category": "family", "hanzi": "家人", "pinyin": "jiārén", "english": "family member(s)" },

  { "id": "time-01", "category": "time", "hanzi": "现在", "pinyin": "xiànzài", "english": "now" },
  { "id": "time-02", "category": "time", "hanzi": "今天", "pinyin": "jīntiān", "english": "today" },
  { "id": "time-03", "category": "time", "hanzi": "昨天", "pinyin": "zuótiān", "english": "yesterday" },
  { "id": "time-04", "category": "time", "hanzi": "明天", "pinyin": "míngtiān", "english": "tomorrow" },
  { "id": "time-05", "category": "time", "hanzi": "早上", "pinyin": "zǎoshang", "english": "morning" },
  { "id": "time-06", "category": "time", "hanzi": "上午", "pinyin": "shàngwǔ", "english": "late morning" },
  { "id": "time-07", "category": "time", "hanzi": "中午", "pinyin": "zhōngwǔ", "english": "noon" },
  { "id": "time-08", "category": "time", "hanzi": "下午", "pinyin": "xiàwǔ", "english": "afternoon" },
  { "id": "time-09", "category": "time", "hanzi": "晚上", "pinyin": "wǎnshang", "english": "evening / night" },
  { "id": "time-10", "category": "time", "hanzi": "点", "pinyin": "diǎn", "english": "o'clock", "note": "三点 = 3 o'clock. Can also mean 'a little'." },
  { "id": "time-11", "category": "time", "hanzi": "半", "pinyin": "bàn", "english": "half", "note": "三点半 = 3:30." },
  { "id": "time-12", "category": "time", "hanzi": "分", "pinyin": "fēn", "english": "minute (clock time)", "note": "三点二十分 = 3:20." },
  { "id": "time-13", "category": "time", "hanzi": "小时", "pinyin": "xiǎoshí", "english": "hour (duration)" },
  { "id": "time-14", "category": "time", "hanzi": "分钟", "pinyin": "fēnzhōng", "english": "minute (duration)", "note": "等五分钟 = wait five minutes." },
  { "id": "time-15", "category": "time", "hanzi": "时间", "pinyin": "shíjiān", "english": "time" },
  { "id": "time-16", "category": "time", "hanzi": "周末", "pinyin": "zhōumò", "english": "weekend" },
  { "id": "time-17", "category": "time", "hanzi": "平时", "pinyin": "píngshí", "english": "usually / normally" },
  { "id": "time-18", "category": "time", "hanzi": "一会儿", "pinyin": "yíhuìr", "english": "a little while", "note": "Very common: 等一会儿 = hold on a sec." },
  { "id": "time-19", "category": "time", "hanzi": "马上", "pinyin": "mǎshàng", "english": "right away / soon", "note": "Literally 'on horse'. 马上到 = almost there." },
  { "id": "time-20", "category": "time", "hanzi": "以后", "pinyin": "yǐhòu", "english": "after / later / in the future" },

