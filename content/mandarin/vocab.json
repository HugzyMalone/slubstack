  { "id": "date-12", "category": "dates", "hanzi": "十二月", "pinyin": "shí'èryuè", "english": "December" },
  { "id": "date-13", "category": "dates", "hanzi": "号", "pinyin": "hào", "english": "day of month", "note": "三月八号 = March 8th. 日 is the formal written form." },
  { "id": "date-14", "category": "dates", "hanzi": "年", "pinyin": "nián", "english": "year" },
