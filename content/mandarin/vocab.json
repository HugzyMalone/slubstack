  {"id": "pv-08", "category": "pronouns-verbs", "hanzi": "这", "pinyin": "zhè", "english": "this", "note": "Often pronounced 'zhèi' in casual speech.", "tones": [4], "tone": 4, "priority": true},
  {"id": "pv-09", "category": "pronouns-verbs", "hanzi": "那", "pinyin": "nà", "english": "that", "note": "Often 'nèi' in speech, and also means 'then / in that case'.", "tones": [4], "tone": 4, "priority": true},
  {"id": "pv-10", "category": "pronouns-verbs", "hanzi": "是", "pinyin": "shì", "english": "to be (is / am / are)", "note": "Only links nouns, not adjectives — don't say 我是高.", "tones": [4], "tone": 4, "priority": true},
