[
  {"id": "greet-01", "category": "greetings", "hanzi": "你好", "pinyin": "nǐ hǎo", "english": "hi / hello", "note": "Universal greeting. In casual texts and among friends, 嗨 or just 诶 is more common.", "tones": [3, 3], "tone": 3, "priority": true},
  {"id": "greet-02", "category": "greetings", "hanzi": "您好", "pinyin": "nín hǎo", "english": "hello (polite)", "note": "Use for elders, strangers, customers, or in formal settings. Using 你好 to an elder can feel curt.", "tones": [2, 3], "tone": 2, "priority": true},
  {"id": "greet-03", "category": "greetings", "hanzi": "嗨", "pinyin": "hāi", "english": "hi", "note": "Borrowed from English. Very casual — friends, chat apps.", "tones": [1], "tone": 1},
  {"id": "greet-04", "category": "greetings", "hanzi": "早", "pinyin": "zǎo", "english": "morning", "note": "Native speakers usually just say 早, not the textbook 早上好.", "tones": [3], "tone": 3},
  {"id": "greet-05", "category": "greetings", "hanzi": "晚安", "pinyin": "wǎn'ān", "english": "good night", "note": "Said at bedtime, not on arrival in the evening.", "tones": [3, 1], "tone": 3},
  {"id": "greet-06", "category": "greetings", "hanzi": "再见", "pinyin": "zàijiàn", "english": "goodbye", "note": "A touch formal in speech; 拜拜 is far more common day-to-day.", "tones": [4], "tone": 4, "priority": true},
  {"id": "greet-07", "category": "greetings", "hanzi": "拜拜", "pinyin": "bài bài", "english": "bye", "note": "The casual goodbye everyone actually says.", "tones": [4, 4], "tone": 4, "priority": true},
  {"id": "greet-08", "category": "greetings", "hanzi": "回头见", "pinyin": "huítóu jiàn", "english": "see you later", "tones": [2, 4], "tone": 2},
  {"id": "greet-09", "category": "greetings", "hanzi": "谢谢", "pinyin": "xièxie", "english": "thanks", "tones": [4], "tone": 4, "priority": true},
  {"id": "greet-10", "category": "greetings", "hanzi": "多谢", "pinyin": "duōxiè", "english": "many thanks", "note": "Slightly warmer / more emphatic than 谢谢.", "tones": [1], "tone": 1},
  {"id": "greet-11", "category": "greetings", "hanzi": "不客气", "pinyin": "bú kèqi", "english": "you're welcome", "note": "Friends often just say 不用谢 or wave it off with 没事.", "tones": [2, 4], "tone": 2},
  {"id": "greet-12", "category": "greetings", "hanzi": "没事", "pinyin": "méi shì", "english": "no worries / it's fine", "note": "The natural reply when a stranger apologises to you.", "tones": [2, 4], "tone": 2},
  {"id": "greet-13", "category": "greetings", "hanzi": "对不起", "pinyin": "duìbuqǐ", "english": "sorry (serious)", "note": "Sincere apology. For small bumps use 不好意思 instead.", "tones": [4], "tone": 4, "priority": true},
  {"id": "greet-14", "category": "greetings", "hanzi": "不好意思", "pinyin": "bù hǎoyìsi", "english": "sorry / excuse me", "note": "The everyday 'sorry' — bumping someone, getting attention, mild apology.", "tones": [4, 3], "tone": 4, "priority": true},
  {"id": "greet-15", "category": "greetings", "hanzi": "没关系", "pinyin": "méi guānxi", "english": "it doesn't matter", "tones": [2, 1], "tone": 2, "priority": true},
  {"id": "greet-16", "category": "greetings", "hanzi": "请问", "pinyin": "qǐng wèn", "english": "excuse me (may I ask)", "note": "How you start a question to a stranger — shopkeeper, passerby, etc.", "tones": [3, 4], "tone": 3, "priority": true},
  {"id": "greet-17", "category": "greetings", "hanzi": "欢迎", "pinyin": "huānyíng", "english": "welcome", "tones": [1], "tone": 1, "priority": true},
  {"id": "greet-18", "category": "greetings", "hanzi": "好久不见", "pinyin": "hǎojiǔ bú jiàn", "english": "long time no see", "tones": [3, 2, 4], "tone": 3},
  {"id": "greet-19", "category": "greetings", "hanzi": "最近怎么样", "pinyin": "zuìjìn zěnmeyàng", "english": "how have you been?", "note": "More natural than the textbook 你好吗? — which people almost never actually say.", "tones": [4, 3], "tone": 4},
  {"id": "greet-20", "category": "greetings", "hanzi": "挺好的", "pinyin": "tǐng hǎo de", "english": "pretty good", "note": "Casual, positive reply. Beats the stiff 我很好.", "tones": [3, 3, 5], "tone": 3},
